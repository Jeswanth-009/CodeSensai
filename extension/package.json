{
  "name": "codesensei",
  "displayName": "CodeSensei 🥋",
  "description": "AI Reasoning Coach for Indian Developers — Powered by AWS Bedrock",
  "version": "1.0.0",
  "publisher": "xfactor",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Education",
    "Other",
    "Machine Learning"
  ],
  "keywords": [
    "AI",
    "learning",
    "India",
    "Hinglish",
    "code explanation",
    "AWS"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codesensei-container",
          "title": "CodeSensei",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "codesensei-container": [
        {
          "type": "webview",
          "id": "codesensei.sidebar",
          "name": "CodeSensei"
        }
      ]
    },
    "commands": [
      {
        "command": "codesensei.explainCode",
        "title": "Ask CodeSensei",
        "category": "CodeSensei"
      },
      {
        "command": "codesensei.explainHinglish",
        "title": "Explain in Hinglish",
        "category": "CodeSensei"
      },
      {
        "command": "codesensei.analyzeComplexity",
        "title": "Analyze Complexity",
        "category": "CodeSensei"
      },
      {
        "command": "codesensei.explainError",
        "title": "Explain Error",
        "category": "CodeSensei"
      },
      {
        "command": "codesensei.exportNotes",
        "title": "Export Notes to Markdown",
        "category": "CodeSensei"
      },
      {
        "command": "codesensei.toggleAutoExplain",
        "title": "Toggle Auto-Explain on Error",
        "category": "CodeSensei"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "codesensei.explainCode",
          "when": "editorHasSelection",
          "group": "codesensei@1"
        },
        {
          "command": "codesensei.explainHinglish",
          "when": "editorHasSelection",
          "group": "codesensei@2"
        },
        {
          "command": "codesensei.analyzeComplexity",
          "when": "editorHasSelection",
          "group": "codesensei@3"
        }
      ]
    },
    "configuration": {
      "title": "CodeSensei",
      "properties": {
        "codesensei.apiUrl": {
          "type": "string",
          "default": "https://9430itxz98.execute-api.ap-south-2.amazonaws.com/prod",
          "description": "Your AWS API Gateway URL for CodeSensei backend"
        },
        "codesensei.defaultMode": {
          "type": "string",
          "enum": [
            "english",
            "hinglish"
          ],
          "default": "english",
          "description": "Default explanation language mode"
        },
        "codesensei.autoExplain": {
          "type": "boolean",
          "default": false,
          "description": "Auto-explain errors when they appear"
        }
      }
    }
  },
  "scripts": {
    "compile": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "dev": "webpack --mode development"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "typescript": "^5.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0",
    "ts-loader": "^9.0.0",
    "babel-loader": "^9.0.0",
    "@babel/core": "^7.0.0",
    "@babel/preset-react": "^7.0.0",
    "@babel/preset-typescript": "^7.0.0",
    "css-loader": "^6.0.0",
    "style-loader": "^3.0.0",
    "postcss-loader": "^7.0.0",
    "autoprefixer": "^10.0.0",
    "tailwindcss": "^3.4.0"
  },
  "dependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
